import { useMemo } from 'react'
import type { Driver, LapRow } from '../types'

export interface TimingRow {
  position: number
  driverName: string
  driverNumber: number
  teamColor: string
  teamName: string
  gap: string
  interval: string
  lastLap: string
  bestLap: string
  bestLapTime: number | null
  tyreCompound: string
  sector1: number | null
  sector2: number | null
  sector3: number | null
  sector1Status: 'purple' | 'green' | 'yellow' | 'none'
  sector2Status: 'purple' | 'green' | 'yellow' | 'none'
  sector3Status: 'purple' | 'green' | 'yellow' | 'none'
  lapsCompleted: number
}

function formatLapTime(seconds: number | null | undefined): string {
  if (seconds == null || !Number.isFinite(seconds) || seconds <= 0) return '—'
  const minutes = Math.floor(seconds / 60)
  const remainder = seconds - minutes * 60
  return `${minutes}:${remainder.toFixed(3).padStart(6, '0')}`
}

function formatGap(seconds: number | null, leader = false): string {
  if (leader) return 'LEADER'
  if (seconds == null || !Number.isFinite(seconds)) return '—'
  return `+${seconds.toFixed(3)}`
}

const EPS = 1e-6

function pickSectorStatus(
  value: number | null,
  sessionBest: number | null,
  personalBest: number | null
): 'purple' | 'green' | 'yellow' | 'none' {
  if (value == null || !Number.isFinite(value)) return 'none'
  if (sessionBest != null && Math.abs(value - sessionBest) < EPS) return 'purple'
  if (personalBest != null && Math.abs(value - personalBest) < EPS) return 'green'
  return 'yellow'
}

export function useTimingData(laps: LapRow[], drivers: Driver[]): TimingRow[] {
  return useMemo(() => {
    if (!drivers.length && !laps.length) return []

    const driversByNumber = new Map<number, Driver>()
    for (const driver of drivers) {
      driversByNumber.set(driver.driverNumber, driver)
    }

    const lapsByDriver = new Map<number, LapRow[]>()
    for (const lap of laps) {
      const number = lap.driverNumber
      if (number == null) continue
      if (!lapsByDriver.has(number)) lapsByDriver.set(number, [])
      lapsByDriver.get(number)!.push(lap)
    }

    const allDriverNumbers = new Set<number>()
    // Always include full driver roster from session metadata.
    for (const key of driversByNumber.keys()) allDriverNumbers.add(key)
    // Keep any extra lap-only driver numbers as fallback.
    for (const key of lapsByDriver.keys()) allDriverNumbers.add(key)

    const sessionBestS1 = laps.reduce<number | null>((min, lap) => {
      if (lap.sector1 == null) return min
      return min == null ? lap.sector1 : Math.min(min, lap.sector1)
    }, null)
    const sessionBestS2 = laps.reduce<number | null>((min, lap) => {
      if (lap.sector2 == null) return min
      return min == null ? lap.sector2 : Math.min(min, lap.sector2)
    }, null)
    const sessionBestS3 = laps.reduce<number | null>((min, lap) => {
      if (lap.sector3 == null) return min
      return min == null ? lap.sector3 : Math.min(min, lap.sector3)
    }, null)

    const rowsWithTotals = Array.from(allDriverNumbers).map((driverNumber) => {
      const driverLaps = [...(lapsByDriver.get(driverNumber) ?? [])].sort((a, b) => {
        const lapDiff = (a.lapNumber ?? 0) - (b.lapNumber ?? 0)
        if (lapDiff !== 0) return lapDiff
        return (a.lapEndSeconds ?? 0) - (b.lapEndSeconds ?? 0)
      })
      const latestLap = driverLaps[driverLaps.length - 1] ?? null

      const sumLapTime = driverLaps.reduce((acc, lap) => acc + (lap.lapTime ?? 0), 0)
      const lastLapEndSeconds =
        latestLap?.lapEndSeconds != null && Number.isFinite(latestLap.lapEndSeconds)
          ? latestLap.lapEndSeconds
          : null
      const totalRaceTime = lastLapEndSeconds ?? (sumLapTime > 0 ? sumLapTime : null)
      const bestLapTime = driverLaps.reduce<number | null>((min, lap) => {
        if (lap.lapTime == null || lap.lapTime <= 0) return min
        return min == null ? lap.lapTime : Math.min(min, lap.lapTime)
      }, null)

      const personalBestS1 = driverLaps.reduce<number | null>((min, lap) => {
        if (lap.sector1 == null) return min
        return min == null ? lap.sector1 : Math.min(min, lap.sector1)
      }, null)
      const personalBestS2 = driverLaps.reduce<number | null>((min, lap) => {
        if (lap.sector2 == null) return min
        return min == null ? lap.sector2 : Math.min(min, lap.sector2)
      }, null)
      const personalBestS3 = driverLaps.reduce<number | null>((min, lap) => {
        if (lap.sector3 == null) return min
        return min == null ? lap.sector3 : Math.min(min, lap.sector3)
      }, null)

      const driverInfo = driversByNumber.get(driverNumber)
      const name = latestLap?.driverName ?? driverInfo?.driverName ?? String(driverNumber)
      const rawPosition =
        latestLap?.position != null && Number.isFinite(latestLap.position) ? latestLap.position : null
      const lapsCompleted = latestLap?.lapNumber ?? 0

      const row: TimingRow = {
        position: 0,
        driverName: name,
        driverNumber,
        teamColor: driverInfo?.teamColor ?? '#666666',
        teamName: driverInfo?.teamName ?? 'Unknown',
        gap: '—',
        interval: '—',
        lastLap: latestLap?.lapTimeFormatted ?? formatLapTime(latestLap?.lapTime),
        bestLap: bestLapTime == null ? '—' : formatLapTime(bestLapTime),
        bestLapTime,
        tyreCompound: latestLap?.tyreCompound ?? 'UNKNOWN',
        sector1: latestLap?.sector1 ?? null,
        sector2: latestLap?.sector2 ?? null,
        sector3: latestLap?.sector3 ?? null,
        sector1Status: pickSectorStatus(latestLap?.sector1 ?? null, sessionBestS1, personalBestS1),
        sector2Status: pickSectorStatus(latestLap?.sector2 ?? null, sessionBestS2, personalBestS2),
        sector3Status: pickSectorStatus(latestLap?.sector3 ?? null, sessionBestS3, personalBestS3),
        lapsCompleted
      }

      return {
        row,
        rawPosition,
        totalRaceTime: totalRaceTime != null && totalRaceTime > 0 ? totalRaceTime : null
      }
    })

    // Stable, deterministic ordering from raw position and tie-breakers.
    rowsWithTotals.sort((a, b) => {
      const aPos = a.rawPosition ?? Number.MAX_SAFE_INTEGER
      const bPos = b.rawPosition ?? Number.MAX_SAFE_INTEGER
      if (aPos !== bPos) return aPos - bPos
      if (a.row.lapsCompleted !== b.row.lapsCompleted) return b.row.lapsCompleted - a.row.lapsCompleted
      const aBest = a.row.bestLapTime ?? Number.MAX_SAFE_INTEGER
      const bBest = b.row.bestLapTime ?? Number.MAX_SAFE_INTEGER
      if (aBest !== bBest) return aBest - bBest
      return a.row.driverNumber - b.row.driverNumber
    })

    const leaderTime = rowsWithTotals[0]?.totalRaceTime ?? null

    return rowsWithTotals.map((entry, idx) => {
      const ahead = idx > 0 ? rowsWithTotals[idx - 1] : null
      const row = entry.row

      // Reindex to 1..N so positions are always unique and contiguous.
      row.position = idx + 1
      row.gap =
        idx === 0
          ? formatGap(0, true)
          : formatGap(entry.totalRaceTime != null && leaderTime != null ? entry.totalRaceTime - leaderTime : null)
      row.interval = idx === 0
        ? '—'
        : formatGap(entry.totalRaceTime != null && ahead?.totalRaceTime != null ? entry.totalRaceTime - ahead.totalRaceTime : null)

      return row
    })
  }, [laps, drivers])
}
