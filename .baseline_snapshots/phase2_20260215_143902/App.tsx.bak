import { useEffect, useMemo, useState } from 'react'
import SessionPicker from './components/SessionPicker'
import TopBar from './components/TopBar'
import { useSessionStore } from './stores/sessionStore'

export default function App() {
  const [pickerOpen, setPickerOpen] = useState(false)

  const loadingState = useSessionStore((s) => s.loadingState)
  const error = useSessionStore((s) => s.error)
  const sessionData = useSessionStore((s) => s.sessionData)

  const summary = useMemo(() => {
    if (!sessionData) return null
    return {
      drivers: sessionData.drivers.length,
      laps: sessionData.laps.length,
      weather: sessionData.weather.length,
      raceControl: sessionData.raceControl.length
    }
  }, [sessionData])

  useEffect(() => {
    if (!sessionData) return
    console.log('laps count:', sessionData.laps?.length)
    console.log('first lap:', sessionData.laps?.[0])
  }, [sessionData])

  return (
    <div className="h-screen w-screen bg-bg-primary text-text-primary">
      <TopBar
        error={error}
        loadingState={loadingState}
        onTogglePicker={() => setPickerOpen((v) => !v)}
        sessionData={sessionData}
      />

      <SessionPicker open={pickerOpen} onClose={() => setPickerOpen(false)} />

      <main className="flex h-full items-center justify-center px-6 pt-12">
        {loadingState === 'idle' && <div className="text-lg text-text-secondary">Select a session to begin</div>}

        {loadingState === 'loading' && (
          <div className="flex items-center gap-3 text-text-secondary">
            <span className="inline-block h-6 w-6 animate-spin rounded-full border-2 border-text-secondary border-t-transparent" />
            <span>Loading session data...</span>
          </div>
        )}

        {loadingState === 'error' && <div className="text-lg text-red-400">{error ?? 'Failed to load session'}</div>}

        {loadingState === 'ready' && summary && (
          <div className="rounded-md border border-border bg-bg-card p-6 text-base">
            Loaded: {summary.drivers} drivers, {summary.laps} laps, {summary.weather} weather readings,{' '}
            {summary.raceControl} race control messages
          </div>
        )}
      </main>
    </div>
  )
}
