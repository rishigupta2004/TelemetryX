import { useMemo } from 'react'
import { usePlaybackStore } from '../stores/playbackStore'
import type { Driver, LapRow } from '../types'

export interface TimingRow {
  position: number
  driverCode: string
  driverName: string
  driverNumber: number
  teamColor: string
  teamName: string
  gap: string
  interval: string
  lastLap: string
  bestLap: string
  bestLapTime: number | null
  tyreCompound: string
  sector1: number | null
  sector2: number | null
  sector3: number | null
  sector1Status: 'purple' | 'green' | 'yellow' | 'none'
  sector2Status: 'purple' | 'green' | 'yellow' | 'none'
  sector3Status: 'purple' | 'green' | 'yellow' | 'none'
  lapsCompleted: number
}

interface InternalRow {
  row: TimingRow
  lapsCompleted: number
  progressInLap: number
  currentPosition: number | null
  elapsedForGap: number | null
}

const EPS = 1e-6

function formatLapTime(seconds: number | null | undefined): string {
  if (seconds == null || !Number.isFinite(seconds) || seconds <= 0) return '—'
  const minutes = Math.floor(seconds / 60)
  const remainder = seconds - minutes * 60
  return `${minutes}:${remainder.toFixed(3).padStart(6, '0')}`
}

function formatRaceDelta(seconds: number | null): string {
  if (seconds == null || !Number.isFinite(seconds)) return '—'
  if (seconds < 60) return `+${seconds.toFixed(3)}`
  const minutes = Math.floor(seconds / 60)
  const remainder = seconds - minutes * 60
  return `+${minutes}:${remainder.toFixed(3).padStart(6, '0')}`
}

function formatLapDelta(lapsBehind: number): string {
  if (lapsBehind <= 0) return '—'
  return `+${lapsBehind} Lap${lapsBehind > 1 ? 's' : ''}`
}

function pickSectorStatus(
  value: number | null,
  sessionBest: number | null,
  personalBest: number | null
): 'purple' | 'green' | 'yellow' | 'none' {
  if (value == null || !Number.isFinite(value)) return 'none'
  if (sessionBest != null && Math.abs(value - sessionBest) < EPS) return 'purple'
  if (personalBest != null && Math.abs(value - personalBest) < EPS) return 'green'
  return 'yellow'
}

export function useTimingData(laps: LapRow[], drivers: Driver[], totalLaps?: number | null): TimingRow[] {
  const currentTime = usePlaybackStore((s) => s.currentTime)
  const playbackSessionStart = usePlaybackStore((s) => s.sessionStartTime)
  const playbackDuration = usePlaybackStore((s) => s.duration)

  return useMemo(() => {
    if (!drivers.length && !laps.length) return []

    const validStarts = laps
      .map((lap) => lap.lapStartSeconds)
      .filter((t) => Number.isFinite(t) && t > 0)
    const fallbackStart = validStarts.length ? Math.min(...validStarts) : 0
    const sessionStartTime = playbackSessionStart || fallbackStart
    const sessionTime = sessionStartTime + Math.max(0, currentTime)

    const driversByNumber = new Map<number, Driver>()
    for (const driver of drivers) driversByNumber.set(driver.driverNumber, driver)

    const lapsByDriver = new Map<number, LapRow[]>()
    for (const lap of laps) {
      if (lap.driverNumber == null) continue
      if (!lapsByDriver.has(lap.driverNumber)) lapsByDriver.set(lap.driverNumber, [])
      lapsByDriver.get(lap.driverNumber)!.push(lap)
    }

    const allDriverNumbers = new Set<number>()
    for (const n of driversByNumber.keys()) allDriverNumbers.add(n)
    for (const n of lapsByDriver.keys()) allDriverNumbers.add(n)

    const allVisibleLaps = laps.filter((lap) => lap.lapStartSeconds <= sessionTime && lap.lapTime != null && lap.lapTime > 0)
    const sessionBestS1 = allVisibleLaps.reduce<number | null>((min, lap) => (lap.sector1 == null ? min : min == null ? lap.sector1 : Math.min(min, lap.sector1)), null)
    const sessionBestS2 = allVisibleLaps.reduce<number | null>((min, lap) => (lap.sector2 == null ? min : min == null ? lap.sector2 : Math.min(min, lap.sector2)), null)
    const sessionBestS3 = allVisibleLaps.reduce<number | null>((min, lap) => (lap.sector3 == null ? min : min == null ? lap.sector3 : Math.min(min, lap.sector3)), null)

    const rows: InternalRow[] = Array.from(allDriverNumbers).map((driverNumber) => {
      const driverLaps = [...(lapsByDriver.get(driverNumber) ?? [])].sort(
        (a, b) => a.lapNumber - b.lapNumber || a.lapEndSeconds - b.lapEndSeconds
      )
      const driverInfo = driversByNumber.get(driverNumber)

      const startedByNow = driverLaps.filter((lap) => lap.lapStartSeconds <= sessionTime)
      const completedByNow = driverLaps.filter(
        (lap) => lap.lapEndSeconds <= sessionTime && lap.lapTime != null && lap.lapTime > 0
      )
      const currentLap =
        startedByNow.find((lap) => lap.lapStartSeconds <= sessionTime && sessionTime <= lap.lapEndSeconds) ?? null
      const lastCompleted = completedByNow[completedByNow.length - 1] ?? null
      const referenceLap = currentLap ?? lastCompleted ?? startedByNow[startedByNow.length - 1] ?? null

      const bestLapTime = completedByNow.reduce<number | null>((min, lap) => {
        if (lap.lapTime == null || lap.lapTime <= 0) return min
        return min == null ? lap.lapTime : Math.min(min, lap.lapTime)
      }, null)

      const personalBestS1 = completedByNow.reduce<number | null>((min, lap) => (lap.sector1 == null ? min : min == null ? lap.sector1 : Math.min(min, lap.sector1)), null)
      const personalBestS2 = completedByNow.reduce<number | null>((min, lap) => (lap.sector2 == null ? min : min == null ? lap.sector2 : Math.min(min, lap.sector2)), null)
      const personalBestS3 = completedByNow.reduce<number | null>((min, lap) => (lap.sector3 == null ? min : min == null ? lap.sector3 : Math.min(min, lap.sector3)), null)

      const lapsCompleted = lastCompleted?.lapNumber ?? 0
      const currentPosition = referenceLap?.position ?? null

      const lapDuration = currentLap ? Math.max(1, currentLap.lapEndSeconds - currentLap.lapStartSeconds) : 1
      const progressInLap = currentLap ? Math.max(0, Math.min(1, (sessionTime - currentLap.lapStartSeconds) / lapDuration)) : 0

      // For a stable relative gap proxy during playback, compare last completed crossing times.
      const elapsedForGap = lastCompleted?.lapEndSeconds != null ? lastCompleted.lapEndSeconds - sessionStartTime : null

      const displayCode = driverInfo?.code ?? referenceLap?.driverName ?? String(driverNumber)
      const displayName = referenceLap?.driverName ?? driverInfo?.driverName ?? String(driverNumber)

      const row: TimingRow = {
        position: 0,
        driverCode: displayCode,
        driverName: displayName,
        driverNumber,
        teamColor: driverInfo?.teamColor ?? '#666666',
        teamName: driverInfo?.teamName ?? 'Unknown',
        gap: lapsCompleted > 0 ? '—' : 'DNS',
        interval: '—',
        lastLap: lastCompleted?.lapTimeFormatted ?? formatLapTime(lastCompleted?.lapTime),
        bestLap: bestLapTime == null ? '—' : formatLapTime(bestLapTime),
        bestLapTime,
        tyreCompound: referenceLap?.tyreCompound ?? '—',
        sector1: referenceLap?.sector1 ?? null,
        sector2: referenceLap?.sector2 ?? null,
        sector3: referenceLap?.sector3 ?? null,
        sector1Status: pickSectorStatus(referenceLap?.sector1 ?? null, sessionBestS1, personalBestS1),
        sector2Status: pickSectorStatus(referenceLap?.sector2 ?? null, sessionBestS2, personalBestS2),
        sector3Status: pickSectorStatus(referenceLap?.sector3 ?? null, sessionBestS3, personalBestS3),
        lapsCompleted
      }

      return { row, lapsCompleted, progressInLap, currentPosition, elapsedForGap }
    })

    rows.sort((a, b) => {
      const aPos = a.currentPosition ?? Number.MAX_SAFE_INTEGER
      const bPos = b.currentPosition ?? Number.MAX_SAFE_INTEGER
      if (aPos !== bPos) return aPos - bPos
      if (a.lapsCompleted !== b.lapsCompleted) return b.lapsCompleted - a.lapsCompleted
      if (a.progressInLap !== b.progressInLap) return b.progressInLap - a.progressInLap
      return a.row.driverNumber - b.row.driverNumber
    })

    const leader = rows[0] ?? null
    const leaderLaps = leader?.lapsCompleted ?? 0

    return rows.map((entry, idx) => {
      const row = entry.row
      row.position = idx + 1

      if (!leader || entry.lapsCompleted === 0) {
        row.gap = 'DNS'
        row.interval = '—'
        return row
      }

      if (idx === 0) {
        row.gap = 'LEADER'
        row.interval = '—'
        return row
      }

      const lapsBehindLeader = Math.max(0, leaderLaps - entry.lapsCompleted)
      if (lapsBehindLeader > 0) {
        row.gap = formatLapDelta(lapsBehindLeader)
      } else {
        row.gap = formatRaceDelta(
          leader.elapsedForGap != null && entry.elapsedForGap != null
            ? entry.elapsedForGap - leader.elapsedForGap
            : null
        )
      }

      const ahead = rows[idx - 1]
      if (!ahead || ahead.lapsCompleted === 0) {
        row.interval = '—'
      } else {
        const lapsBehindAhead = Math.max(0, ahead.lapsCompleted - entry.lapsCompleted)
        if (lapsBehindAhead > 0) {
          row.interval = formatLapDelta(lapsBehindAhead)
        } else {
          row.interval = formatRaceDelta(
            ahead.elapsedForGap != null && entry.elapsedForGap != null
              ? entry.elapsedForGap - ahead.elapsedForGap
              : null
          )
        }
      }

      // Keep DNF/DNS at bottom once race has progressed through most laps.
      if (totalLaps && row.lapsCompleted > 0 && row.lapsCompleted < totalLaps * 0.5 && currentTime > 0.9 * playbackDuration) {
        row.gap = 'DNF'
      }

      return row
    })
  }, [laps, drivers, totalLaps, currentTime, playbackSessionStart, playbackDuration])
}
