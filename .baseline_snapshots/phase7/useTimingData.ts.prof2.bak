import { useMemo } from 'react'
import { usePlaybackStore } from '../stores/playbackStore'
import { useSessionStore } from '../stores/sessionStore'
import type { Driver, LapRow } from '../types'

export interface TimingRow {
  position: number
  driverCode: string
  driverName: string
  driverNumber: number
  teamColor: string
  teamName: string
  gap: string
  interval: string
  lastLap: string
  bestLap: string
  bestLapTime: number | null
  tyreCompound: string
  sector1: number | null
  sector2: number | null
  sector3: number | null
  sector1Status: 'purple' | 'green' | 'yellow' | 'none'
  sector2Status: 'purple' | 'green' | 'yellow' | 'none'
  sector3Status: 'purple' | 'green' | 'yellow' | 'none'
  status: 'racing' | 'pit' | 'out' | 'dnf' | 'dns'
  currentLap: number
  currentSector: 1 | 2 | 3
  lapsCompleted: number
}

interface DriverSnapshot {
  row: TimingRow
  totalTime: number
}

const EPS = 1e-6

function formatLapTime(seconds: number | null | undefined): string {
  if (seconds == null || !Number.isFinite(seconds) || seconds <= 0) return '—'
  const mins = Math.floor(seconds / 60)
  const secs = (seconds % 60).toFixed(3)
  return mins > 0 ? `${mins}:${secs.padStart(6, '0')}` : secs
}

function formatGap(seconds: number): string {
  if (!Number.isFinite(seconds) || seconds <= 0) return '—'
  if (seconds < 60) return `+${seconds.toFixed(3)}`
  const mins = Math.floor(seconds / 60)
  const secs = (seconds % 60).toFixed(3)
  return `+${mins}:${secs.padStart(6, '0')}`
}

function pickSectorStatus(
  value: number | null,
  sessionBest: number | null,
  personalBest: number | null
): TimingRow['sector1Status'] {
  if (value == null || !Number.isFinite(value)) return 'none'
  if (sessionBest != null && Math.abs(value - sessionBest) < EPS) return 'purple'
  if (personalBest != null && Math.abs(value - personalBest) < EPS) return 'green'
  return 'yellow'
}

function isValidLap(lap: LapRow): boolean {
  return !!lap.lapTime && lap.lapTime > 0 && lap.isValid !== false && lap.isDeleted !== true
}

export function useTimingData(): TimingRow[] {
  const sessionData = useSessionStore((s) => s.sessionData)
  const lapsFromStore = useSessionStore((s) => s.laps)
  const currentTime = usePlaybackStore((s) => s.currentTime)
  const sessionStartTime = usePlaybackStore((s) => s.sessionStartTime)
  const roundedTime = Math.round(currentTime * 2) / 2

  return useMemo(() => {
    if (!sessionData?.drivers?.length) return []

    const drivers = sessionData.drivers
    const allLaps = lapsFromStore.length ? lapsFromStore : sessionData.laps
    if (!allLaps.length) return []

    const startCandidates = allLaps
      .map((lap) => lap.lapStartSeconds)
      .filter((t) => Number.isFinite(t) && t > 0)
    const effectiveSessionStart = sessionStartTime || (startCandidates.length ? Math.min(...startCandidates) : 0)
    const effectiveSessionTime = effectiveSessionStart + Math.max(0, roundedTime)

    const visibleCompleted = allLaps.filter((lap) => lap.lapEndSeconds <= effectiveSessionTime && isValidLap(lap))
    const sessionBestS1 = visibleCompleted.reduce<number | null>((min, lap) => (lap.sector1 == null ? min : min == null ? lap.sector1 : Math.min(min, lap.sector1)), null)
    const sessionBestS2 = visibleCompleted.reduce<number | null>((min, lap) => (lap.sector2 == null ? min : min == null ? lap.sector2 : Math.min(min, lap.sector2)), null)
    const sessionBestS3 = visibleCompleted.reduce<number | null>((min, lap) => (lap.sector3 == null ? min : min == null ? lap.sector3 : Math.min(min, lap.sector3)), null)
    const globalMaxLap = allLaps.reduce((max, lap) => Math.max(max, lap.lapNumber || 0), 0)

    const snapshots: DriverSnapshot[] = drivers.map((driver: Driver) => {
      const driverLaps = allLaps
        .filter((lap) => lap.driverName === driver.code || lap.driverNumber === driver.driverNumber)
        .sort((a, b) => a.lapNumber - b.lapNumber || a.lapEndSeconds - b.lapEndSeconds)

      if (driverLaps.length === 0) {
        return {
          totalTime: 0,
          row: {
            position: 99,
            driverCode: driver.code || '???',
            driverName: driver.driverName || '',
            driverNumber: driver.driverNumber,
            teamColor: driver.teamColor || '#666666',
            teamName: driver.teamName || 'Unknown',
            gap: '—',
            interval: '—',
            lastLap: '—',
            bestLap: '—',
            bestLapTime: null,
            tyreCompound: '—',
            sector1: null,
            sector2: null,
            sector3: null,
            sector1Status: 'none',
            sector2Status: 'none',
            sector3Status: 'none',
            status: 'dns',
            currentLap: 0,
            currentSector: 1,
            lapsCompleted: 0
          }
        }
      }

      const completedLaps = driverLaps.filter((lap) => lap.lapEndSeconds <= effectiveSessionTime && isValidLap(lap))
      const lastCompleted = completedLaps[completedLaps.length - 1] ?? null

      let currentLapData = lastCompleted ?? driverLaps[0]
      let inLiveLap = false
      for (const lap of driverLaps) {
        if (lap.lapStartSeconds <= effectiveSessionTime && effectiveSessionTime <= lap.lapEndSeconds) {
          currentLapData = lap
          inLiveLap = true
          break
        }
        if (effectiveSessionTime >= lap.lapEndSeconds) currentLapData = lap
      }

      const lapTimes = completedLaps.map((lap) => lap.lapTime || 0).filter((t) => t > 0)
      const bestLapTime = lapTimes.length ? Math.min(...lapTimes) : null
      const totalTime = lapTimes.reduce((sum, t) => sum + t, 0)
      const lapsCompleted = completedLaps.length ? completedLaps[completedLaps.length - 1].lapNumber : 0

      const personalBestS1 = completedLaps.reduce<number | null>((min, lap) => (lap.sector1 == null ? min : min == null ? lap.sector1 : Math.min(min, lap.sector1)), null)
      const personalBestS2 = completedLaps.reduce<number | null>((min, lap) => (lap.sector2 == null ? min : min == null ? lap.sector2 : Math.min(min, lap.sector2)), null)
      const personalBestS3 = completedLaps.reduce<number | null>((min, lap) => (lap.sector3 == null ? min : min == null ? lap.sector3 : Math.min(min, lap.sector3)), null)

      const maxLap = driverLaps[driverLaps.length - 1]
      let status: TimingRow['status'] = 'racing'
      if (driverLaps[0].lapStartSeconds > effectiveSessionTime + 300) status = 'dns'
      else if (maxLap.lapNumber < globalMaxLap - 2 && effectiveSessionTime > maxLap.lapEndSeconds) status = 'dnf'

      const lapDuration = Math.max(1, currentLapData.lapEndSeconds - currentLapData.lapStartSeconds)
      const lapProgress = Math.max(0, Math.min(1, (effectiveSessionTime - currentLapData.lapStartSeconds) / lapDuration))
      if (status === 'racing' && lapDuration > 120 && lapProgress > 0.85) status = 'pit'

      let currentSector: 1 | 2 | 3 = 1
      if (lapProgress > 0.33 && lapProgress <= 0.66) currentSector = 2
      if (lapProgress > 0.66) currentSector = 3

      let sector1: number | null = null
      let sector2: number | null = null
      let sector3: number | null = null
      if (!inLiveLap || effectiveSessionTime >= currentLapData.lapEndSeconds) {
        sector1 = currentLapData.sector1 ?? null
        sector2 = currentLapData.sector2 ?? null
        sector3 = currentLapData.sector3 ?? null
      } else {
        sector1 = currentSector >= 2 ? currentLapData.sector1 ?? null : null
        sector2 = currentSector >= 3 ? currentLapData.sector2 ?? null : null
        sector3 = null
      }

      return {
        totalTime,
        row: {
          position: currentLapData.position || 99,
          driverCode: driver.code || currentLapData.driverName || '???',
          driverName: driver.driverName || currentLapData.driverName || '',
          driverNumber: driver.driverNumber,
          teamColor: driver.teamColor || '#666666',
          teamName: driver.teamName || 'Unknown',
          gap: '—',
          interval: '—',
          lastLap: formatLapTime(lastCompleted?.lapTime ?? null),
          bestLap: formatLapTime(bestLapTime),
          bestLapTime,
          tyreCompound: currentLapData.tyreCompound || '—',
          sector1,
          sector2,
          sector3,
          sector1Status: pickSectorStatus(sector1, sessionBestS1, personalBestS1),
          sector2Status: pickSectorStatus(sector2, sessionBestS2, personalBestS2),
          sector3Status: pickSectorStatus(sector3, sessionBestS3, personalBestS3),
          status,
          currentLap: currentLapData.lapNumber || 0,
          currentSector,
          lapsCompleted
        }
      }
    })

    snapshots.sort((a, b) => {
      if (a.row.status === 'dns' && b.row.status !== 'dns') return 1
      if (b.row.status === 'dns' && a.row.status !== 'dns') return -1
      if (a.row.status === 'dnf' && b.row.status !== 'dnf') return 1
      if (b.row.status === 'dnf' && a.row.status !== 'dnf') return -1
      if (a.row.position !== b.row.position) return a.row.position - b.row.position
      if (a.row.currentLap !== b.row.currentLap) return b.row.currentLap - a.row.currentLap
      return a.totalTime - b.totalTime
    })

    const leader = snapshots.find((s) => s.row.status !== 'dns' && s.row.status !== 'dnf') ?? null
    if (leader) {
      leader.row.gap = 'LEADER'
      leader.row.interval = '—'
    }

    for (let i = 0; i < snapshots.length; i++) {
      const current = snapshots[i]
      current.row.position = i + 1
      if (!leader || current === leader) continue
      if (current.row.status === 'dns') {
        current.row.gap = 'DNS'
        current.row.interval = '—'
        continue
      }
      if (current.row.status === 'dnf') {
        current.row.gap = 'DNF'
        current.row.interval = '—'
        continue
      }

      const lapDeltaToLeader = Math.max(0, leader.row.currentLap - current.row.currentLap)
      current.row.gap =
        lapDeltaToLeader > 0
          ? `+${lapDeltaToLeader} Lap${lapDeltaToLeader > 1 ? 's' : ''}`
          : formatGap(current.totalTime - leader.totalTime)

      const ahead = snapshots
        .slice(0, i)
        .reverse()
        .find((entry) => entry.row.status !== 'dns' && entry.row.status !== 'dnf')
      if (!ahead) {
        current.row.interval = '—'
        continue
      }

      const lapDeltaToAhead = Math.max(0, ahead.row.currentLap - current.row.currentLap)
      current.row.interval = lapDeltaToAhead > 0 ? `+${lapDeltaToAhead} Lap` : formatGap(current.totalTime - ahead.totalTime)
    }

    return snapshots.map((snapshot) => snapshot.row)
  }, [sessionData, lapsFromStore, roundedTime, sessionStartTime])
}
