import React, { useMemo, useState } from 'react'
import { useCarPositions } from '../hooks/useCarPositions'
import {
  getBounds,
  interpolateAlongPath,
  parseCenterline,
  toPolylinePoints
} from '../lib/trackGeometry'
import { useSessionStore } from '../stores/sessionStore'

interface TrackMapProps {
  compact?: boolean
}

export function TrackMap({ compact = false }: TrackMapProps) {
  const sessionData = useSessionStore((s) => s.sessionData)
  const carPositions = useCarPositions()
  const [hoveredDriver, setHoveredDriver] = useState<string | null>(null)

  const trackData = useMemo(() => {
    const geo = sessionData?.trackGeometry
    if (!geo?.centerline?.length) return null

    const points = parseCenterline(geo.centerline as number[][])
    const bounds = getBounds(points)
    const width = bounds.maxX - bounds.minX
    const height = bounds.maxY - bounds.minY

    return {
      points,
      bounds,
      width,
      height,
      corners: geo.corners || [],
      sectors: geo.sectors || [],
      drsZones: geo.drsZones || []
    }
  }, [sessionData?.trackGeometry])

  if (!trackData) {
    return <div className="flex h-full items-center justify-center text-sm text-text-muted">Track layout not available</div>
  }

  const { points, bounds, width, height, sectors } = trackData
  const viewBox = `${bounds.minX} ${bounds.minY} ${width} ${height}`

  return (
    <div className="relative h-full w-full overflow-hidden rounded-md bg-bg-card">
      <div className="absolute left-3 top-2 z-10 text-xs uppercase tracking-wider text-text-secondary">
        {sessionData?.trackGeometry?.name || 'Track'}
      </div>

      <svg viewBox={viewBox} className="h-full w-full" preserveAspectRatio="xMidYMid meet">
        <polyline
          points={toPolylinePoints(points)}
          fill="none"
          stroke="#333333"
          strokeWidth={14}
          strokeLinecap="round"
          strokeLinejoin="round"
        />
        <polyline
          points={toPolylinePoints(points)}
          fill="none"
          stroke="#444444"
          strokeWidth={10}
          strokeLinecap="round"
          strokeLinejoin="round"
        />

        {points.length > 1 && (
          <line
            x1={points[0].x - 8}
            y1={points[0].y}
            x2={points[0].x + 8}
            y2={points[0].y}
            stroke="#ffffff"
            strokeWidth={3}
          />
        )}

        {sectors.map((sector: any, i: number) => {
          const idx = sector?.startIndex ?? sector?.start ?? Math.floor((i / 3) * points.length)
          if (idx >= points.length) return null
          const p = points[idx]
          return (
            <g key={`sector-${i}`}>
              <circle cx={p.x} cy={p.y} r={4} fill="#666" />
              <text x={p.x + 8} y={p.y + 4} fill="#888" fontSize="10">
                S{i + 1}
              </text>
            </g>
          )
        })}

        {carPositions.map((car) => {
          const pos = interpolateAlongPath(points, car.progress)
          const isHovered = hoveredDriver === car.driverCode
          const radius = compact ? 5 : 7

          return (
            <g
              key={car.driverNumber}
              onMouseEnter={() => setHoveredDriver(car.driverCode)}
              onMouseLeave={() => setHoveredDriver(null)}
              style={{ cursor: 'pointer' }}
            >
              <circle
                cx={pos.x}
                cy={pos.y}
                r={isHovered ? radius + 2 : radius}
                fill={car.teamColor}
                stroke={isHovered ? '#ffffff' : 'none'}
                strokeWidth={2}
                opacity={car.isInPit ? 0.4 : 1}
              />
              {(!compact || isHovered) && (
                <text
                  x={pos.x + radius + 3}
                  y={pos.y + 4}
                  fill="#ffffff"
                  fontSize={compact ? '8' : '10'}
                  fontFamily="monospace"
                  fontWeight="bold"
                >
                  {car.driverCode}
                </text>
              )}
            </g>
          )
        })}
      </svg>

      {hoveredDriver && !compact && (
        <div className="absolute bottom-2 left-3 z-10 rounded border border-border bg-bg-secondary px-2 py-1 text-xs">
          {(() => {
            const car = carPositions.find((c) => c.driverCode === hoveredDriver)
            if (!car) return null
            return (
              <span>
                <span style={{ color: car.teamColor }}>●</span> {car.driverCode} — P{car.position || '—'} — Lap{' '}
                {car.currentLap}
                {car.isInPit ? ' (PIT)' : ''}
              </span>
            )
          })()}
        </div>
      )}
    </div>
  )
}
