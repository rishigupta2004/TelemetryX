# TelemetryX local defaults (no Docker required)
TELEMETRYX_DATA_SOURCE=duckdb
REDIS_ENABLED=0
TELEMETRYX_REQUIRE_AUTH=0

# Optional: backend CORS
TELEMETRYX_CORS_ORIGINS=*

# Optional: data root override
# TELEMETRYX_DATA_ROOT=/absolute/path/to/backend/etl/data

# Optional: ClickHouse mode (only if you run ClickHouse yourself)
# TELEMETRYX_DATA_SOURCE=clickhouse
# CLICKHOUSE_HOST=127.0.0.1
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DATABASE=telemetryx
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# Optional: Redis mode (only if you run Redis yourself)
# REDIS_ENABLED=1
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
